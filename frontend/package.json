{
  "name": "dmis-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "NODE_PATH=./node_modules playwright test --config ../playwright.config.ts",
    "e2e:headed": "NODE_PATH=./node_modules playwright test --headed --config ../playwright.config.ts",
    "e2e:install": "NODE_PATH=./node_modules playwright install --with-deps chromium",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "tsc -b && vite build && node scripts/check-css-size.mjs",
    "build:report": "tsc -b && vite build && node scripts/print-bundle-size.mjs",
    "test": "NODE_OPTIONS=\"--localstorage-file=/tmp/dmis-vitest-localstorage.json\" vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.100.9",
    "dompurify": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "rehype-raw": "^7.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.11.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
