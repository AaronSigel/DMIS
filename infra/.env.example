DB_URL=jdbc:postgresql://postgres:5432/dmis
DB_USER=dmis
# Keep DB_PASSWORD and POSTGRES_PASSWORD equal unless you intentionally split DB users.
DB_PASSWORD=change-me-postgres-password

JWT_SECRET=change-me-super-secret-change-me-super-secret
JWT_EXPIRATION_SECONDS=3600
SPRING_PROFILES_ACTIVE=demo

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=dmis-documents
MINIO_PRESIGNED_DOWNLOAD_TTL_SECONDS=300

POSTGRES_DB=dmis
POSTGRES_USER=dmis
POSTGRES_PASSWORD=change-me-postgres-password

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-root-password

AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-4o-mini
# Required when AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=

EMBEDDINGS_BASE_URL=http://embeddings-service:8001
AI_BASE_URL=http://ai-service:8002
STT_BASE_URL=http://stt-service:8000
STT_CONNECT_TIMEOUT_MS=2000
STT_READ_TIMEOUT_MS=60000
STT_DEFAULT_PROFILE=fast
MAILCOW_BASE_URL=
SOGO_BASE_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=true
SMTP_CONNECT_TIMEOUT_MS=5000
SMTP_READ_TIMEOUT_MS=10000
SMTP_WRITE_TIMEOUT_MS=10000
MAIL_FROM=no-reply@dmis.local
BACKEND_BASE_URL=http://backend:8080/api
VITE_API_BASE_URL=/api

EMBEDDINGS_MODEL_PATH=/models/bge-m3
EMBEDDINGS_RERANKER_MODEL_PATH=/models/bge-reranker-v2-m3
STT_MODEL_PATH=/models/whisper-medium
STT_MODEL_PATH_FAST=/models/whisper-small
STT_MODEL_PATH_ACCURATE=/models/whisper-medium
DEVICE=cpu
COMPUTE_TYPE=int8
STT_PROFILE=fast
STT_BEAM_SIZE_FAST=1
STT_BEAM_SIZE_ACCURATE=3
